# --- Supabase (yerel geliştirme için `supabase start` çıktısından doldur) ---
# Mobil (Expo) — EXPO_PUBLIC_ önekli değişkenler client'a gömülür
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Web + Panel (Next.js)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sadece sunucu tarafı (Edge Functions / Next server) — ASLA client'a sızdırma
SUPABASE_SERVICE_ROLE_KEY=

# Ödeme (iyzico) — sunucu tarafı
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

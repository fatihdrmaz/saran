# Expo + Metro çoğu paketi düz (hoisted) node_modules ister; pnpm'in symlink
# yapısı React Native bundler ile sorun çıkarır. Bu yüzden hoisted linker.
node-linker=hoisted
# Tek React kopyası garantisi (mobil/web/panel arası peer çakışmasını önler)
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*expo*
shamefully-hoist=true

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "composite": true,
    "paths": {
      "@saran/tokens": ["./packages/tokens/src/index.ts"],
      "@saran/shared": ["./packages/shared/src/index.ts"],
      "@saran/supabase": ["./packages/supabase/src/index.ts"]
    }
  }
}

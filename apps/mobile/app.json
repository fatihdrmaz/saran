{
  "expo": {
    "name": "Yara Takibi",
    "slug": "saran",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saran",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.yaratakibi.app",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yaratakibi.app",
      "adaptiveIcon": {
        "backgroundColor": "#0E7A63",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E3B31",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Yara fotoğrafınızı seçebilmeniz için galeri erişimi gereklidir. Fotoğraflar şifreli saklanır ve yalnızca atanmış hemşireniz görebilir.",
          "cameraPermission": "Yaranızın fotoğrafını çekebilmeniz için kamera erişimi gereklidir. Fotoğraflar şifreli saklanır ve yalnızca atanmış hemşireniz görebilir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
